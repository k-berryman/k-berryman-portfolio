            "p": {
              "color": "#767676",
              "padding": "0",
              "letter-spacing": "0px"
            },
            ".panel-title": {
              "border-bottom": "2px solid @border",
              "display": "flex!important",
              "justify-content": "space-between",
              "align-items": "center",
              "padding-right": "2rem"
            },
            ".collapsed": {
              "span": {
                "transform": "rotate(0deg)"
              },
              "border": "none"
            },
            "span": {
              "font-size": "1.4rem",
              "transition": "all 0.3s",
              "transform": "rotate(45deg)",
              "background": "linear-gradient(to left, @secondaryColor, @primaryColor)",
              "-webkit-background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "font-weight": "900"
            },
            ".panel-body": {
              "padding-top": "0.5rem"
            },
            ".card": {
              "border-radius": "0px",
              "margin-bottom": "-1px",
              ".card-header": {
                "border-radius": "0px",
                "margin": "0.5rem 0",
                "border": "0px",
                "background": "@tabsColor",
                "padding": "0",
                "a.panel-title": {
