          "_name": "accordions1",
          "_customHTML": "<section class=\"accordion1\" group=\"Accordions\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Accordion</header>\n        <input type=\"color\" title=\"Tabs Color\" name=\"tabsColor\" value=\"#191919\" selected>\n        <input type=\"color\" title=\"Active Border Color\" name=\"border\" value=\"#5758e0\" selected>\n        <select title=\"Toggles Count\" name=\"bootstrapAccordion\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n            <input type=\"video\" title=\"Video\" value=\"http://www.youtube.com/watch?v=uNCr7NdOJgw\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay&&bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay&&bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay&&bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-12 col-md-12\">\n                <div class=\"section-head text-center\">\n                    <h2 class=\"mbr-section-title mbr-bold pb-2 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        Skills</h2>\n                    <p class=\"mbr-section-text align-center pb-4 mbr-regular mbr-black mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-text\">Software Engineering Tools</p>\n                </div>\n                <div class=\"clearfix\"></div>\n                <div id=\"bootstrap-toggle\" class=\"toggle-panel accordionStyles tab-content\">\n                    <div class=\"card\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">Languages</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    JavaScript, TypeScript, Python, Java, C#, C++, C, VHDL</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"bootstrapAccordion > 1\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">JavaScript Tools</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n\n                        </div>\n                        <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    React, React Native, Node, Next.js, Express, Tailwind CSS, D3, Jest, Redux</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"bootstrapAccordion > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">Python Tools</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Plotly, Pandas, Flask, Django</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"bootstrapAccordion > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">Additional</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    UI, UX, CX, Figma, Google Cloud Platform (GCP), AWS, Postgres, MySQL, MongoDB, CI/CD, Jenkins, GitHub Actions, Stripe, Grafana, Prometheus, Docker, Kubernetes, Shell Scripting, Vim, A/B Testing, Statsig, Postman, Falco, Mapbox, REST APIs, GitHub Copilot, Scrum, Jira, Ubuntu, git</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"bootstrapAccordion > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">Graphic Design</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Mauris et elit vitae lectus\n                                    convallis scelerisque. Cras vestibulum blandit lorem, at fringilla nisl sollicitudin\n                                    ac. Nunc venenatis nec neque sed semper. Mauris viverra, sapien sed fringilla\n                                    egestas, sem felis condimentum augue, vitae sodales sem metus in ex. Aenean massa\n                                    velit, sollicitudin quis elementum sit amet, vehicula sed nunc.</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"bootstrapAccordion > 5\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"collapsed panel-title\" data-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                <h4 class=\"mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\">Media Buying</h4>\n                                <span class=\"sign mbr-iconfont mbri-plus inactive\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style mbr-regular mbr-text panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Donec facilisis felis arcu, vitae vestibulum massa lobortis eget. Ut pellentesque\n                                    purus feugiat, tristique magna ac, luctus est. Vivamus sit amet magna venenatis,\n                                    bibendum erat eu, tincidunt justo. Aenean viverra sollicitudin neque, sed bibendum\n                                    nulla mollis id. Aenean massa velit, sollicitudin quis elementum sit amet, vehicula\n                                    sed nunc. Proin sit amet aliquet dui.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "s1YPFUMG3v",
          "_anchor": "accordions1-a",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "people1",
          "_customHTML": "<section class=\"people1\" group=\"People\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"4\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Card Profession \" name=\"showProf\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Color\" name=\"iconColor\" value=\"#55b4d4\" selected condition=\"showIcon\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\" selected>6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/edgem5/components/_images/background5.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/edgem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"text-container\">\n                <h2 class=\"mbr-section-title mbr-fonts-style align-center\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>\n                    Testimonials (LinkedIn)</b></h2>\n            </div>\n            <div class=\"cards-container col-12\">\n                <div class=\"card\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin is full of Exceptional talent!!! No matter what you put in front of her she will figure it out and as being a self starter she will get things done without supervision !!! I recommend and endorse Kaitlin to take any challenges put in front of her!!!</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Bob Jones</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Sr. Manager of Program Management at NASA 2013 - 2021</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 1\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin's energy, positivity, and relentless curiosity make her an excellent contributor to the culture of any workspace. She shows tremendous empathy both for customers and her fellow developers. Working to truly understand the customer's needs and pain points to craft helpful solutions while simultaneously acting as a \"rubber duck\" for coworkers grappling with code issues.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Matthew Carpenter</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Co-Founder &amp; Head of Product at Gaia AI -- Forbes 30 Under 30</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card\" mbr-if=\"cardsAmount > 2\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin has an incredible amount of energy and passion for her work. She cares deeply about user experience and creating responsive front-end designs. Her energy was infectious in the office and helped keep everything bright and light!<br></h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Acshi Haggenmiller</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Robotics PhD</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 3\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin brought an incredible energy to the team that made the office a happier place. She helped everyone look forward to showing up to work. She is a capable frontend developer and extends herself to help the people around her, from having meetings with our designer to help align designs with implementation and sync up on the same timeline to prepare for deadlines, to helping lead discussions on our database schema. Anyone who gets to work with Kaitlin will be lucky!</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Peter McHale</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Co-Founder &amp; CEO of Gaia AI -- MIT -- Forbes 30 Under 30</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card\" mbr-if=\"cardsAmount > 4\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin embodies an impressive combination of enthusiasm, creativity, drive, and self-awareness. She works well independently, but isn't afraid to seek guidance when necessary, as evidenced by her quick implementation of a graphical web application from a vague spec I provided, with only minimal guidance from me. Her passion for the projects she takes on is contagious, and she has a natural talent for inspiring and motivating others on her team. Kaitlin always eager to learn and explore new things. She would be an asset to any software development team.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Jeff Meunier</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Sr. Software Engineer &amp; Adjunct Professor</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 5\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin is an energetic and creative engineer who loves the next challenge. She was certainly a positive cultural addition to our company, and her personality is infectious. She brings a positive attitude and will infuse the entire team with the notion that anything is possible. It is a joy to work with Kaitlin and she brings not only engineer skills, but also project management and creative design skills. I hope I have the pleasure of working with Kaitlin again.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Brain Geisel</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Founder &amp; CEO of Symage &amp; Geisel Software</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".container": {
              "max-width": "1312px"
            },
            ".row": {
              "padding": "0 1rem",
              "@media (max-width: 991px)": {
                "padding": "0 0.75rem"
              }
            },
            ".text-container": {
              "width": "100%",
              "padding": "0"
            },
            ".mbr-section-title": {
              "margin-bottom": "4rem",
              "width": "100%",
              "color": "#ffffff"
            },
            ".cards-container": {
              "display": "grid",
              "-webkit-box-orient": "vertical",
              "-webkit-box-direction": "normal",
              "-webkit-flex-direction": "column",
              "-ms-flex-direction": "column",
              "flex-direction": "column",
              "grid-auto-columns": "1fr",
              "grid-column-gap": "8rem",
              "grid-row-gap": "4rem",
              "-ms-grid-columns": "1fr 1fr",
              "grid-template-columns": "1fr 1fr",
              "-ms-grid-rows": "auto",
              "grid-template-rows": "auto",
              "padding": "0",
              "@media (max-width: 991px)": {
                "max-width": "30rem",
                "margin-right": "auto",
                "margin-left": "auto",
                "-ms-grid-columns": "1fr",
                "grid-template-columns": "1fr"
              }
            },
            ".card-wrapper": {
              "display": "flex",
              "flex-direction": "row",
              "align-items": "flex-start",
              "justify-content": "flex-start",
              "flex-wrap": "nowrap",
              "@media (max-width: 991px)": {
                "flex-direction": "column"
              }
            },
            ".card-title": {
              "color": "#ffffff"
            },
            ".card-name-text": {
              "margin-top": "2rem"
            },
            ".card-name": {
              "color": "#0077ff"
            },
            ".card-prof": {
              "color": "#0095ff"
            },
            ".mbr-iconfont": {
              "font-size": "25px",
              "color": "@iconColor"
            },
            ".icon-box": {
              "margin-right": "2rem",
              "display": "flex",
              "justify-content": "center"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_cid": "vazqVB9Wh9",
          "_anchor": "people1-a",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "people1",
          "_sourceTheme": "solutionm4",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".container": {
              "max-width": "1312px"
            },
            ".row": {
              "padding": "0 1rem",
              "@media (max-width: 991px)": {
                "padding": "0 0.75rem"
              }
            },
            ".text-container": {
              "width": "100%",
              "padding": "0"
            },
            ".mbr-section-title": {
              "margin-bottom": "4rem",
              "width": "100%",
              "color": "#ffffff"
            },
            ".cards-container": {
              "display": "grid",
              "-webkit-box-orient": "vertical",
              "-webkit-box-direction": "normal",
              "-webkit-flex-direction": "column",
              "-ms-flex-direction": "column",
              "flex-direction": "column",
              "grid-auto-columns": "1fr",
              "grid-column-gap": "8rem",
              "grid-row-gap": "4rem",
              "-ms-grid-columns": "1fr 1fr",
              "grid-template-columns": "1fr 1fr",
              "-ms-grid-rows": "auto",
              "grid-template-rows": "auto",
              "padding": "0",
              "@media (max-width: 991px)": {
                "max-width": "30rem",
                "margin-right": "auto",
                "margin-left": "auto",
                "-ms-grid-columns": "1fr",
                "grid-template-columns": "1fr"
              }
            },
            ".card-wrapper": {
              "display": "flex",
              "flex-direction": "row",
              "align-items": "flex-start",
              "justify-content": "flex-start",
              "flex-wrap": "nowrap",
              "@media (max-width: 991px)": {
                "flex-direction": "column"
              }
            },
            ".card-title": {
              "color": "#ffffff"
            },
            ".card-name-text": {
              "margin-top": "2rem"
            },
            ".card-name": {
              "color": "#0077ff"
            },
            ".card-prof": {
              "color": "#0095ff"
            },
            ".mbr-iconfont": {
              "font-size": "25px",
              "color": "@iconColor"
            },
            ".icon-box": {
              "margin-right": "2rem",
              "display": "flex",
              "justify-content": "center"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_customHTML": "<section class=\"people1\" group=\"People\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"4\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Card Profession \" name=\"showProf\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Color\" name=\"iconColor\" value=\"#55b4d4\" selected condition=\"showIcon\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background5.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"text-container\">\n                <h2 class=\"mbr-section-title mbr-fonts-style align-center\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>\n                    Testimonials</b></h2>\n            </div>\n            <div class=\"cards-container col-12\">\n                <div class=\"card\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin worked as my manager at Color Me Mine, Norfolk, and did an amazing job at maintaining both a hard-working and fun-loving environment. She is a people person and always prioritizes the best interest of her employees as well as her customers -- and she is also incredibly friendly and keeps spirits high even under times of stress! Kaitlin has so much to offer and would be an incredible asset to any team or workspace. Kaitlin, thank you for all your help and everything that you do for us at the studio. I appreciate you!!</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Lydia Del Olmo</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Executive Assistant</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 1\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">I met Kaitlin back in high school, during First Robotics. She wasn't even on my team, yet she was helpful, knowledgeable, and, as someone more experienced to the sport, gave me quite a few pointers that helped me a lot going forward with my robotics.<br><br>A year later, and she joined CSH along with me and instantly got involved. She has an impressive drive to learn and to get stuff done. After a busy freshman year, she joined CSH's E-Board her sophomore year as Research and Development, helping people complete projects by encouraging seminars, hackathons, connecting members with compatible skill sets, and purchasing some serious hardware for the org.<br><br>Kaitlin is not only a talent engineer, she's a collaborator, and a leader. She has a diverse technical skillset that she has employed not just in CSH, but in the larger RIT community. Being on a powerhouse robotics team was just a warmup for her.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Will Nilges</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Backend Programmer @ Datadog</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card\" mbr-if=\"cardsAmount > 2\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">I was always excited about what Kaitlin would bring to the table at any time we talked or worked together. When we studied together at RIT, she was the Project Director for Computer Science House (CSH) and helped me with my major project for the year. Her intelligent insight was always amazing to hear, and I loved working with her as someone I could look up to for help. I was constantly in awe at how confidently she could talk and convince a room full of her peers about her ideas, even if many of them were not on the same page at the beginning. Kaitlin's dazzling personality would be a tragedy to miss in any workplace, and any job would be lucky to have such a hard worker on their team.<br></h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Dani Saba</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Senior Privacy &amp; Compliance Analyst -- MS in Cybersecurity</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 3\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin has acted as the Research and Development Director for our organization, and during her time as that role she did an excellent job. Kaitlin kept members of the organization interested in doing new projects and provided them with opportunities to work and learn from senior members of the organization. Once projects were started or completed, she catalogued all of them in an actively updated document so that all members of the organization could know the current status of various projects. Kaitlin is hard working, efficient, enthusiastic, and a pleasure to work with.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Matthew Sze-Tu</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Software Developer</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card\" mbr-if=\"cardsAmount > 4\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin embodies an impressive combination of enthusiasm, creativity, drive, and self-awareness. She works well independently, but isn't afraid to seek guidance when necessary, as evidenced by her quick implementation of a graphical web application from a vague spec I provided, with only minimal guidance from me. Her passion for the projects she takes on is contagious, and she has a natural talent for inspiring and motivating others on her team. Kaitlin always eager to learn and explore new things. She would be an asset to any software development team.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Jeff Meunier</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Sr. Software Engineer &amp; Adjunct Professor</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount > 5\">\n                    <div class=\"card-wrapper\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-quote-left mobi-mbri\" style=\"font-size: 56px;\"></span>\n                        </div>\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Kaitlin is an energetic and creative engineer who loves the next challenge. She was certainly a positive cultural addition to our company, and her personality is infectious. She brings a positive attitude and will infuse the entire team with the notion that anything is possible. It is a joy to work with Kaitlin and she brings not only engineer skills, but also project management and creative design skills. I hope I have the pleasure of working with Kaitlin again.</h4>\n                            <div class=\"card-name-text\">\n                                <p class=\"card-name mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".card-name\"><b>Brain Geisel</b></p>\n                                <p class=\"card-prof mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showProf\" data-app-selector=\".card-prof\">Founder &amp; CEO of Symage &amp; Geisel Software</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "people1-b",
          "_isUserblock": true,
          "_cid": "vazv6TQcaE",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".card-wrapper": {
              "display": "flex",
              "padding": "0 1.5rem",
              "@media (max-width: 1600px)": {
                "padding": "0"
              }
            },
            ".row": {
              "flex-direction": "row-reverse"
            },
            ".form-control, .field-input": {
              "padding": "1rem"
            },
            ".form-row > .col, .col-auto": {
              "padding-right": "8px",
              "padding-left": "8px"
            },
            ".btn": {
              "margin": "0!important",
              "height": "56px",
              "border-radius": "3px!important",
              "padding": "0 1.5rem",
              "span": {
                "font-size": "1rem"
              }
            },
            "& when (@customStyle)": {
              ".form-control, .field-input": {
                "padding": "1rem",
                "background-color": "@fieldColor",
                "border-color": "@borderColor",
                "color": "@formText",
                "transition": "0.4s",
                "box-shadow": "none",
                "outline": "none",
                "&::-webkit-input-placeholder, &::-webkit-input-placeholder": {
                  "color": "@formPlaceholder"
                },
                "&:-moz-placeholder, &:-moz-placeholder": {
                  "color": "@formPlaceholder"
                },
                "&:hover, &:focus": {
                  "background-color": "@fieldHover",
                  "border-color": "@borderHover",
                  "color": "@formFocusText",
                  "box-shadow": "none",
                  "outline": "none",
                  "&::-webkit-input-placeholder, &::-webkit-input-placeholder": {
                    "color": "@formFocusPlaceholder"
                  },
                  "&:-moz-placeholder, &:-moz-placeholder": {
                    "color": "@formFocusPlaceholder"
                  }
                }
              },
              ".jq-number__spin:hover, .jq-number__spin:focus": {
                "background-color": "@fieldHover",
                "border-color": "@borderHover",
                "color": "contrast(@formText, #000000, #ffffff, 30%)",
                "box-shadow": "none",
                "outline": "none"
              },
              ".jq-number__spin": {
                "background-color": "@fieldColor",
                "border-color": "@borderColor",
                "color": "@formText",
                "transition": "0.4s",
                "box-shadow": "none",
                "outline": "none"
              },
              ".jq-selectbox li, .jq-selectbox li": {
                "background-color": "@fieldColor",
                "color": "contrast(@fieldColor, #000000, #ffffff, 30%)"
              },
              ".jq-selectbox li:hover, .jq-selectbox li.selected": {
                "background-color": "@fieldHover",
                "color": "contrast(@fieldHover, #000000, #ffffff, 30%)"
              },
              ".jq-selectbox:hover .jq-selectbox__trigger-arrow, .jq-number__spin.minus:hover:after, .jq-number__spin.plus:hover:after": {
                "border-top-color": "@fieldColor",
                "border-bottom-color": "@fieldColor"
              },
              ".jq-selectbox .jq-selectbox__trigger-arrow, .jq-number__spin.minus:after, .jq-number__spin.plus:after": {
                "border-top-color": "@fieldHover",
                "border-bottom-color": "@fieldHover"
              }
            },
            "& when (@customStyle), (@disableElements)": {
              "input::-webkit-clear-button": {
                "display": "none"
              },
              "input::-webkit-inner-spin-button": {
                "display": "none"
              },
              "input::-webkit-outer-spin-button": {
                "display": "none"
              },
              "input::-webkit-calendar-picker-indicator": {
                "display": "none"
              }
            },
            "H4": {
              "color": "#ffffff"
            },
            "P": {
              "color": "#999999"
            },
            "@media (max-width: 767px)": {
              ".col": {
                "min-width": "100%"
              },
              ".col-auto": {
                "margin": "auto"
              },
              ".card-wrapper": {
                "flex-direction": "column",
                "margin": "auto",
                "text-align": "center",
                ".icon-wrapper": {
                  "margin": "0 auto",
                  "margin-bottom": "1rem"
                }
              }
            },
            ".content": {
              "padding": "0 3rem",
              "@media (max-width: 1600px)": {
                "padding": "0 1rem"
              }
            },
            ".img-wrapper": {
              "position": "relative",
              "overflow": "hidden",
              "&:before": {
                "content": "''",
                "position": "absolute",
                "width": "600px",
                "height": "600px",
                "right": "-300px",
                "border-radius": "50%",
                "bottom": "-350px",
                "opacity": "0.3",
                "background": "@primaryColor",
                "z-index": "2",
                "pointer-events": "none"
              }
            },
            "img": {
              "width": "100%"
            },
            ".card-wrapper .mbr-iconfont": {
              "font-size": "3rem",
              "background": "linear-gradient(to left, @secondaryColor, @primaryColor)",
              "-webkit-background-clip": "text",
              "-webkit-text-fill-color": "transparent"
            },
            ".line": {
              "width": "55px",
              "margin-bottom": "0.5rem",
              "height": "5px",
              "display": "inline-block",
              "background": "linear-gradient(to left, @secondaryColor, @primaryColor)"
            },
            ".icon-wrapper": {
              "margin": "auto",
              "margin-right": "1.5rem",
              "display": "flex",
              "justify-content": "center",
              "border-radius": "50%"
            },
            "h4": {
              "margin": "0"
            },
            ".card-text": {
              "color": "#999999"
            },
            ".mbr-text": {
              "color": "#000000"
            },
            ".card-title": {
              "color": "#ffffff"
            },
            "@media (min-width: 1200px)": {
              ".mbr-text": {
                "max-width": "600px"
              }
            },
            "@media (max-width: 991px)": {
              ".mbr-text": {
                "padding-bottom": "2rem",
                "max-width": "100%"
              }
            },
            ".icon-wrap": {
              "background": "linear-gradient(to left, @secondaryColor, @primaryColor)",
              "width": "100px",
              "height": "100px",
              "display": "flex",
              "cursor": "pointer",
              "justify-content": "center",
              "align-items": "center",
              "border-radius": "50%",
              "z-index": "5",
              ".mbr-iconfont": {
                "font-size": "2.6rem",
                "color": "white",
                "padding-left": "10px"
              },
              "position": "absolute",
              "bottom": "3rem",
              "right": "3rem"
            },
            "H3": {
              "color": "#787324"
            },
            ".mbr-section-title, .title-wrapper": {
              "color": "#ffffff"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#999999"
            },
            ".modalWindow": {
              "position": "fixed",
              "z-index": "5000",
              "left": "0",
              "top": "0",
              "background-color": "rgba(61, 61, 61, 0.65)",
              "width": "100%",
              "height": "100%",
              ".modalWindow-container": {
                "display": "table-cell",
                "vertical-align": "middle"
              },
              ".modalWindow-video": {
                "height": "calc(80vw / 1.778)",
                "width": "80vw",
                "margin": "0 auto"
              }
            },
            "a.close": {
              "position": "absolute",
              "right": "4vw",
              "top": "4vh",
              "color": "#ffffff",
              "z-index": "5000000",
              "font-size": "37px",
              "background": "#000",
              "padding": "20px",
              "border-radius": "50%",
              "&:hover": {
                "color": "#ffffff"
              }
            }
          },
          "_name": "form2",
          "_customHTML": "<section class=\"form2\" group=\"Forms\" plugins=\"formstyler, datepicker\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"9\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"text\" title=\"Modal Video\" name=\"modalVideo\" value=\"https://www.youtube.com/watch?v=VCyrZ_qzSvU\">\n        <input type=\"checkbox\" title=\"Main Title\" name=\"showmainTitle\" checked>\n        <input type=\"checkbox\" title=\"Main Text\" name=\"showmainText\" checked>\n        <header>Form</header>\n        <input type=\"checkbox\" name=\"customStyle\" title=\"Custom Style\" checked>\n        <input type=\"checkbox\" name=\"disableElements\" title=\"Disable Control\">\n        <input type=\"color\" name=\"fieldColor\" title=\"Field\" value=\"#040402\" condition=\"customStyle\">\n        <input type=\"color\" name=\"fieldHover\" title=\"Field Hover\" value=\"#040402\" condition=\"customStyle\">\n        <input type=\"color\" name=\"borderColor\" title=\"Border\" value=\"#555555\" condition=\"customStyle\">\n        <input type=\"color\" name=\"borderHover\" title=\"Border Hover\" value=\"#555555\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formText\" title=\"Text\" value=\"#ffffff\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formFocusText\" title=\"Text Focus\" value=\"#ffffff\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formPlaceholder\" title=\"Placeholders\" value=\"#999999\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formFocusPlaceholder\" title=\"Placeholders Focus\" value=\"#999999\" condition=\"customStyle\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background3.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#040402\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n        <input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container\">\n        <div class=\"row jc-sb\" mbr-cards=\"bootstrap\">\n            <div class=\"col-lg-6 img-col col-md-12 md-pb\">\n                <div class=\"img-wrapper\">\n                    <div class=\"mbr-media show-modal align-center\" data-modal=\".modalWindow\">\n                        <div class=\"icon-wrap\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-play mobi-mbri\"></span>\n                        </div>\n                    </div>\n                    <img src=\"@PROJECT_PATH@/assets/images/mbr-1106x620.jpeg\" alt=\"Mobirise\">\n                </div>\n            </div>\n            <div class=\"col-lg-6 content col-md-12 md-pb\">\n                <div class=\"title-wrapper align-left\">\n                    <div class=\"line\" mbr-if=\"showmainTitle\"></div>\n                    <h3 class=\"mbr-section-title mbr-white mbr-semibold pb-3 mbr-fonts-style\" data-app-selector=\".mbr-section-title, .title-wrapper\" mbr-theme-style=\"display-2\" mbr-if=\"showmainTitle\">Let's Connect!</h3>\n                    <p class=\"mbr-text pb-3 mbr-white mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showmainText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Currently accepting new client requests. Please leave your contact information below, and I'll reach out to you shortly. Thanks for your interest in my work! You can also call or text me at&nbsp;757-601-6266.</p>\n                </div>\n                <div mbr-form class=\"mbr-form\">\n                    <!--Formbuilder Form-->\n                    <form action=\"kaitlinberryman@gmail.com\" name=\"Form Name\" method=\"POST\" class=\"mbr-form form-with-styler\">\n                        <div class=\"form-row\">\n                            <div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">Thanks for reaching out to me! I'll get back to you shortly.</div>\n                            <div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\">Oops...! some\n                                problem!</div>\n                        </div>\n                        <div class=\"dragArea form-row\">\n                            <div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"name\">\n                                <input type=\"text\" name=\"name\" placeholder=\"Name\" data-form-field=\"name\" mbr-theme-style=\"display-7\" class=\"form-control\" value>\n                            </div>\n                            <div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"email\">\n                                <input type=\"email\" name=\"email\" placeholder=\"Email\" data-form-field=\"email\" mbr-theme-style=\"display-7\" class=\"form-control\" value>\n                            </div>\n                            <div data-for=\"phone\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n                                <input type=\"tel\" name=\"phone\" placeholder=\"Phone\" data-form-field=\"phone\" mbr-theme-style=\"display-7\" class=\"form-control\" pattern=\"*\" value>\n                            </div>\n                            <div class=\"col-auto mbr-section-btn\" mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a type=\"submit\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">CONNECT</a></div>\n                        </div>\n                    </form>\n                    <!--Formbuilder Form-->\n                </div>\n            </div>\n        </div>\n        <div class=\"modalWindow\" style=\"display: none;\">\n            <div class=\"modalWindow-container\">\n                <div class=\"modalWindow-video-container\">\n                    <div class=\"modalWindow-video\">\n                        <iframe width=\"100%\" height=\"100%\" data-src=\"{{modalVideo}}\" frameborder=\"0\" allowfullscreen=\"1\"></iframe>\n                    </div>\n                    <a class=\"close\" role=\"button\" data-dismiss=\"modal\">\n                        <span aria-hidden=\"true\" class=\"mbri-close mbr-iconfont closeModal\"></span>\n                        <span class=\"sr-only\">Close</span>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "s1YPpR5DLc",
          "_anchor": "form2-5",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    }
  }
}