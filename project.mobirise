              "background-size": "cover",
              "padding-top": "15rem",
              "align-items": "center",
              "&:after": {
                "position": "absolute",
                "content": "''",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background": "black",
                "opacity": "0.2",
                "z-index": "1"
